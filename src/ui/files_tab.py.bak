# ============================================================================
# PATH SANITIZATION INTEGRATION
# ============================================================================

def sanitize_display_path(path: str, component: str = "files_tab") -> str:
    """
    Sanitize a path before displaying in UI.
    
    CRITICAL: Call this before ANY path is shown to investigator!
    
    This enforces the forensic integrity contract:
    "FEPD SHALL NEVER expose analyzer-side filesystem paths."
    """
    try:
        return safe_path(path, component)
    except ForensicIntegrityError as e:
        logger.error(f"[FORENSIC INTEGRITY] Path leak blocked: {e}")
        return "[PATH PROTECTED]"


