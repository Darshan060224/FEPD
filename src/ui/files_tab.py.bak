    def _auto_expand_tree(self):
        """Auto-expand the first two levels of the tree for visibility."""
        try:
            # Expand all root nodes
            for row in range(self.model.rowCount()):
                root_idx = self.model.index(row, 0)
                self.tree_view.expand(root_idx)
                
                # Also expand first-level children (Evidence/EVTX, etc.)
                for child_row in range(self.model.rowCount(root_idx)):
                    child_idx = self.model.index(child_row, 0, root_idx)
                    self.tree_view.expand(child_idx)
        except Exception as e:
            logger.debug(f"Could not auto-expand tree: {e}")
    
    def refresh(self) -> None:
        """Refresh the tree from VFS."""
        self.model.refresh()
        self._auto_expand_tree()
        self._update_stats()
    
    def _update_stats(self) -> None:
        """Update statistics label - Windows Explorer style."""
        try:
            stats = self.vfs.get_statistics()
            total_files = stats.get('total_files', 0)
            total_folders = stats.get('total_folders', 0)
            
            # Windows Explorer style stats
            self.stats_label.setText(f"{total_files:,} items")
            self.status_items.setText(f"{total_files:,} items")
        except Exception as e:
            logger.debug(f"Failed to update stats: {e}")
            self.stats_label.setText("0 items")
            self.status_items.setText("0 items")
    
    def _on_selection_changed(self, selected, deselected):
        """Handle selection change with terminal sync and user context detection."""
        indexes = self.tree_view.selectedIndexes()
        if indexes:
            node = self.model.get_node_by_index(indexes[0])
            if node:
                self.details_panel.show_node(node)
                self.node_selected.emit(node)
                
                # Update current path tracking and navigation history
                if self._current_path != node.path:
                    self._add_to_history(node.path)
                self._current_path = node.path
                
                # Update breadcrumb navigation (Windows Explorer address bar style)
                self._update_breadcrumb(node.path)
                
                # Update address bar icon
                if node.is_directory:
                    self.address_icon.setText("📁")
                else:
                    self.address_icon.setText("📄")
                
                # Check for user profile context
                old_user = self._current_user
                self._current_user = self._detect_user_context(node.path)
                
                # Update user context indicator (subtle, like Windows)
                if self._current_user:
                    self.user_context_label.setText(f"User: {self._current_user}")
                    self.user_context_label.setToolTip(f"Browsing user profile: {self._current_user}")
                    self.user_context_label.setVisible(True)
                else:
                    self.user_context_label.setText("")
                    self.user_context_label.setToolTip("")
                    self.user_context_label.setVisible(False)
                
                # Emit signals for terminal integration
                self.path_changed.emit(node.path)
                if self._current_user != old_user:
                    self.user_context_changed.emit(self._current_user or "")
                
                # Log to CoC
                self._log_coc("FILE_SELECTED", {
                    "path": node.path,
                    "type": node.node_type.value,
                    "user_context": self._current_user
                })
        else:
            self.details_panel.clear()
            self._current_path = ""
            self.breadcrumb_path.setText("This PC")
            self.user_context_label.setText("")
    
    def _update_breadcrumb(self, path: str):
        """
        Update breadcrumb navigation display with Windows Explorer-style format.
        Shows actual Windows paths like C:\\Users\\John\\Desktop
        
        FORENSIC INTEGRITY: All paths are sanitized before display.
        
        Examples:
            /This PC -> This PC
            /This PC/C: -> C:\\
            /This PC/C:/Users/John/Desktop -> C:\\Users\\John\\Desktop
        """
        if not path:
            self.breadcrumb_path.setText("This PC")
            return
        
        # Split path into segments
        parts = path.strip('/').split('/')
        if not parts or parts == ['']:
            self.breadcrumb_path.setText("This PC")
            return
        
        # Build Windows-style path (C:\Users\John\Desktop)
        if parts[0] == 'This PC':
            if len(parts) == 1:
                # Just "This PC"
                self.breadcrumb_path.setText("This PC")
                return
            elif len(parts) >= 2 and ':' in parts[1]:
                # We have a drive letter like C:
                drive = parts[1]  # C:
                if len(parts) == 2:
                    # Just the drive: C:\
                    windows_path = f"{drive}\\"
                else:
                    # Full path: C:\Users\John\Desktop
                    windows_path = drive + "\\" + "\\".join(parts[2:])
                
                # FORENSIC INTEGRITY: Sanitize before display
                windows_path = sanitize_display_path(windows_path, "breadcrumb")
                
                self.breadcrumb_path.setText(windows_path)
                self.breadcrumb_path.setToolTip(windows_path)
                return
            else:
                # Special partition (Recovery, EFI, etc.)
                partition_name = parts[1]
                if len(parts) == 2:
                    self.breadcrumb_path.setText(partition_name)
                else:
                    windows_path = partition_name + "\\" + "\\".join(parts[2:])
                    # FORENSIC INTEGRITY: Sanitize before display
                    windows_path = sanitize_display_path(windows_path, "breadcrumb")
                    self.breadcrumb_path.setText(windows_path)
                self.breadcrumb_path.setToolTip(path)
                return
        else:
            # Non-standard path, show as-is with backslashes
            display = "\\".join(parts)
            # FORENSIC INTEGRITY: Sanitize before display
            display = sanitize_display_path(display, "breadcrumb")
            self.breadcrumb_path.setText(display)
            self.breadcrumb_path.setToolTip(path)
    
    def _detect_user_context(self, path: str) -> Optional[str]:
        """Detect if path is within a user profile folder."""
        if not path:
            return None
        
        path_lower = path.lower()
        
        # Windows user paths
        if '/users/' in path_lower:
            parts = path.split('/')
            try:
                users_idx = next(i for i, p in enumerate(parts) if p.lower() == 'users')
                if users_idx + 1 < len(parts):
                    username = parts[users_idx + 1]
                    if username.lower() not in ('public', 'default', 'default user', 'all users'):
                        return username
            except StopIteration:
                pass
        
        # Linux/Mac home paths
        elif '/home/' in path_lower:
            parts = path.split('/')
            try:
                home_idx = next(i for i, p in enumerate(parts) if p.lower() == 'home')
                if home_idx + 1 < len(parts):
                    return parts[home_idx + 1]
            except StopIteration:
                pass
        
        return None
    
    def _on_double_click(self, index: QModelIndex):
        """Handle double-click on item - navigate or open."""
        node = self.model.get_node_by_index(index)
        if not node:
            return
        
        if node.is_directory:
            # Expand/collapse in tree
            if self.tree_view.isExpanded(index):
                self.tree_view.collapse(index)
            else:
                self.tree_view.expand(index)
            
            # Emit terminal cd command for sync
            self.terminal_command.emit(f"cd {node.path}")
            
            # Log to CoC
            self._log_coc("DIRECTORY_ENTERED", {
                "path": node.path,
                "name": node.name,
                "user_context": self._detect_user_context(node.path)
            })
        else:
            # Open file in safe viewer
            self._open_file(node)
    
    def _show_context_menu(self, position):
        """Show right-click forensic context menu."""
        index = self.tree_view.indexAt(position)
        if not index.isValid():
            return
        
        node = self.model.get_node_by_index(index)
        if not node:
            return
        
        menu = QMenu(self)
        menu.setStyleSheet("""
            QMenu {
                background-color: #252525;
                color: #e0e0e0;
                border: 1px solid #3d3d3d;
                padding: 4px;
            }
            QMenu::item {
                padding: 8px 24px;
            }
            QMenu::item:selected {
                background-color: #094771;
            }
            QMenu::item:disabled {
                color: #666;
            }
            QMenu::separator {
                height: 1px;
                background: #3d3d3d;
                margin: 4px 0;
            }
        """)
        
        # ====================================
        # FORENSIC ALLOWED OPERATIONS
        # ====================================
        
        if not node.is_directory:
            # File viewing actions
            open_action = menu.addAction("📄 Open (Safe Viewer)")
            open_action.triggered.connect(lambda: self._open_file(node))
            
            menu.addSeparator()
            
            # Forensic viewing options
            text_action = menu.addAction("📝 Text View")
            text_action.triggered.connect(lambda: self._open_with_viewer(node, "text"))
            
            hex_action = menu.addAction("🔢 Hex View")
            hex_action.triggered.connect(lambda: self._open_with_viewer(node, "hex"))
            
            strings_action = menu.addAction("🔤 Strings Extract")
            strings_action.triggered.connect(lambda: self._extract_strings(node))
            
            menu.addSeparator()
            
            # Hash verification
            hash_action = menu.addAction("🔐 Compute SHA-256")
            hash_action.triggered.connect(lambda: self._compute_hash(node))
        
        # Common actions for both files and folders
        details_action = menu.addAction("ℹ️ Properties / Metadata")
        details_action.triggered.connect(lambda: self._show_details(node))
        
        if not node.is_directory:
            menu.addSeparator()
            
            # Jump to timeline if available
            timeline_action = menu.addAction("📅 Jump to Timeline")
            timeline_action.triggered.connect(lambda: self._jump_to_timeline(node))
            
            # Locate in artifacts
            artifacts_action = menu.addAction("🔍 Locate in Artifacts")
            artifacts_action.triggered.connect(lambda: self._locate_in_artifacts(node))
            
            menu.addSeparator()
            
            # Export (creates a copy - does not modify evidence)
            export_action = menu.addAction("📤 Export to Workspace")
            export_action.setToolTip("Creates a copy in your workspace (does not modify evidence)")
            export_action.triggered.connect(lambda: self._export_file(node))
        
        # ====================================
        # BLOCKED OPERATIONS (with visual cue)
        # ====================================
        
        menu.addSeparator()
        blocked_header = menu.addAction("━━━ ⛔ BLOCKED (Forensic Mode) ━━━")
        blocked_header.setEnabled(False)
        
        # Delete - BLOCKED
        delete_action = menu.addAction("🚫 Delete")
        delete_action.setEnabled(False)
        delete_action.triggered.connect(lambda: block_write_operation(self, "Delete"))
        
        # Rename - BLOCKED  
        rename_action = menu.addAction("🚫 Rename")
        rename_action.setEnabled(False)
        rename_action.triggered.connect(lambda: block_write_operation(self, "Rename"))
        
        # Cut - BLOCKED
        cut_action = menu.addAction("🚫 Cut")
        cut_action.setEnabled(False)
        cut_action.triggered.connect(lambda: block_write_operation(self, "Cut"))
        
        # Paste - BLOCKED
        paste_action = menu.addAction("🚫 Paste")
        paste_action.setEnabled(False)
        paste_action.triggered.connect(lambda: block_write_operation(self, "Paste"))
        
        # Edit - BLOCKED
        edit_action = menu.addAction("🚫 Edit")
        edit_action.setEnabled(False)
        edit_action.triggered.connect(lambda: block_write_operation(self, "Edit"))
        
        menu.addSeparator()
        
        # CoC notice
        coc_notice = menu.addAction("🔒 All actions logged to Chain of Custody")
        coc_notice.setEnabled(False)
        
        menu.exec(self.tree_view.viewport().mapToGlobal(position))
    
    def _jump_to_timeline(self, node: VFSNode):
        """Emit signal to jump to this file in the timeline view."""
        # Log to CoC
        self._log_coc("TIMELINE_JUMP_REQUESTED", {
            "path": node.path,
            "name": node.name,
            "modified": node.modified.isoformat() if node.modified else None
        })
        # Emit terminal command to show timeline
        self.terminal_command.emit(f"timeline {node.path}")
    
    def _locate_in_artifacts(self, node: VFSNode):
        """Emit signal to locate this file in artifacts analysis."""
        # Log to CoC
        self._log_coc("ARTIFACT_LOCATE_REQUESTED", {
            "path": node.path,
            "name": node.name
        })
        # Emit terminal command
        self.terminal_command.emit(f"artifacts --locate {node.path}")
    
    def _open_file(self, node: VFSNode):
        """Open file with appropriate viewer."""
        ext = node.name.lower().rsplit('.', 1)[-1] if '.' in node.name else ''
        
        # Log to CoC
        self._log_coc("FILE_OPENED", {
            "path": node.path,
            "name": node.name,
            "size": node.size,
            "hash": node.sha256
        })
        
        # Determine viewer type
        if ext in ('pdf',):
            viewer_type = "pdf"
        elif ext in ('jpg', 'jpeg', 'png', 'gif', 'bmp', 'ico', 'tiff', 'tif', 'webp'):
            viewer_type = "image"
        elif ext in ('mp4', 'avi', 'mkv', 'mov', 'wmv', 'mp3', 'wav', 'flac', 'ogg'):
            viewer_type = "video"
        elif ext in ('txt', 'log', 'csv', 'json', 'xml', 'html', 'htm', 'py', 'js',
                     'css', 'md', 'ini', 'cfg', 'conf', 'bat', 'ps1', 'sh'):
            viewer_type = "text"
        else:
            # Default to hex for unknown types
            viewer_type = "hex"
        
        self._open_with_viewer(node, viewer_type)
    
    def _open_with_viewer(self, node: VFSNode, viewer_type: str):
        """Open file with specific viewer type."""
        # Import viewers
        from src.ui.viewers import (
            TextViewer, HexViewer, ImageViewer, PDFViewer, VideoViewer
        )
        
        # Create viewer
        viewers = {
            "text": TextViewer,
            "hex": HexViewer,
            "image": ImageViewer,
            "pdf": PDFViewer,
            "video": VideoViewer,
        }
        
        ViewerClass = viewers.get(viewer_type, TextViewer)
        viewer = ViewerClass(read_file_func=self.read_file_func)
        
        # Read file data
        data = None
        if self.read_file_func:
            try:
                data = self.read_file_func(node.path, 0, -1)
            except Exception as e:
                logger.error(f"Failed to read file: {e}")
        
        # Load and show
        viewer.load_file(node.path, data)
        viewer.setWindowTitle(f"{node.name} - FEPD Viewer")
        viewer.resize(800, 600)
        viewer.show()
        
        # Track viewer
        self._viewers[node.path] = viewer
        
        # Log to CoC
        self._log_coc("FILE_VIEWED", {
            "path": node.path,
            "viewer": viewer_type,
            "hash": node.sha256
        })
        
        self.file_opened.emit(node.path, viewer_type)
    
    def _show_details(self, node: VFSNode):
        """Show detailed file information dialog."""
        from src.ui.viewers import FileDetailsDialog
        
        dialog = FileDetailsDialog(node, self)
        dialog.exec()
        
        # Log to CoC
        self._log_coc("FILE_DETAILS_VIEWED", {
            "path": node.path
        })
    
    def _compute_hash(self, node: VFSNode) -> None:
        """Compute and display file hash with caching."""
        import hashlib
        
        if not self.read_file_func:
            QMessageBox.warning(self, "Hash Error", "File reading functionality is not available.\n\nPlease ensure the case is properly loaded.")
            return
        
        # Check cache first
        if node.path in self._hash_cache:
            cached = self._hash_cache[node.path]
            QMessageBox.information(
                self, "File Hashes (Cached)",
                f"<b>{node.name}</b><br><br>"
                f"<b>SHA-256:</b><br><code>{cached['sha256']}</code><br><br>"
                f"<b>MD5:</b><br><code>{cached['md5']}</code><br><br>"
                f"<small>✓ Retrieved from cache</small>"
            )
            return
        
        # Show loading indicator
        self._show_loading(STATUS_COMPUTING_HASH)
        QApplication.processEvents()
        
        try:
            # Read file in chunks for large files
            sha256_hash = hashlib.sha256()
            md5_hash = hashlib.md5()
            
            file_size = node.size or 0
            bytes_read = 0
            
            while bytes_read < file_size:
                chunk_size = min(HASH_BUFFER_SIZE, file_size - bytes_read)
                data = self.read_file_func(node.path, bytes_read, chunk_size)
                if not data:
                    break
                sha256_hash.update(data)
                md5_hash.update(data)
                bytes_read += len(data)
                
                # Update loading indicator
                progress = int((bytes_read / file_size) * 100) if file_size > 0 else 100
                self._show_loading(f"{STATUS_COMPUTING_HASH} {progress}%")
                QApplication.processEvents()
            
            sha256 = sha256_hash.hexdigest()
            md5 = md5_hash.hexdigest()
            
            # Cache the result
            self._hash_cache[node.path] = {"sha256": sha256, "md5": md5}
            
            self._hide_loading()
            
            QMessageBox.information(
                self, "File Hashes",
                f"<b>{node.name}</b><br><br>"
                f"<b>SHA-256:</b><br><code>{sha256}</code><br><br>"
                f"<b>MD5:</b><br><code>{md5}</code>"
            )
            
            # Log to CoC
            self._log_coc("HASH_COMPUTED", {
                "path": node.path,
                "sha256": sha256,
                "md5": md5
            })
        except Exception as e:
            self._hide_loading()
            logger.error(f"Hash computation failed for {node.path}: {e}")
            QMessageBox.critical(
                self, "Hash Computation Error",
                f"Failed to compute hash for:\n{node.name}\n\nError: {str(e)}\n\nThe file may be corrupted or inaccessible."
            )
    
    def _export_file(self, node: VFSNode) -> None:
        """Export file to analyst workspace with progress indication."""
        from PyQt6.QtWidgets import QFileDialog
        
        # Get save location
        save_path, _ = QFileDialog.getSaveFileName(
            self, "Export File", node.name
        )
        
        if not save_path:
            return
        
        if not self.read_file_func:
            QMessageBox.warning(self, "Export Error", "File reading functionality is not available.\n\nPlease ensure the case is properly loaded.")
            return
        
        # Show loading indicator
        self._show_loading(STATUS_EXPORTING)
        QApplication.processEvents()
        
        try:
            data = self.read_file_func(node.path, 0, -1)
            if data:
                with open(save_path, 'wb') as f:
                    f.write(data)
                
                self._hide_loading()
                
                QMessageBox.information(
                    self, "Export Complete",
                    f"✓ File exported successfully to:\n{save_path}\n\nSize: {self._format_size(len(data))}"
                )
                
                # Log to CoC
                self._log_coc("FILE_EXPORTED", {
                    "source_path": node.path,
                    "export_path": save_path,
                    "hash": node.sha256,
                    "size": len(data)
                })
            else:
                self._hide_loading()
                QMessageBox.warning(self, "Export Error", "Could not read file data.\n\nThe file may be empty or inaccessible.")
        except Exception as e:
            self._hide_loading()
            logger.error(f"Export failed for {node.path}: {e}")
            QMessageBox.critical(
                self, "Export Error",
                f"Failed to export file:\n{node.name}\n\nError: {str(e)}\n\nPlease check disk space and file permissions."
            )
    
    def _setup_keyboard_shortcuts(self):
        """Set up forensic keyboard shortcuts with write-block protection."""
        from PyQt6.QtGui import QShortcut, QKeySequence
        
        # =====================================================================
        # BLOCKED SHORTCUTS (write operations)
        # =====================================================================
        
        # Block Delete key
        delete_shortcut = QShortcut(QKeySequence("Delete"), self)
        delete_shortcut.activated.connect(lambda: block_write_operation(self, "Delete"))
        
        # Block Ctrl+X (Cut)
        cut_shortcut = QShortcut(QKeySequence("Ctrl+X"), self)
        cut_shortcut.activated.connect(lambda: block_write_operation(self, "Cut (Ctrl+X)"))
        
        # Block F2 (Rename)
        rename_shortcut = QShortcut(QKeySequence("F2"), self)
        rename_shortcut.activated.connect(lambda: block_write_operation(self, "Rename (F2)"))
        
        # Block Ctrl+V (Paste) - no pasting into evidence
        paste_shortcut = QShortcut(QKeySequence("Ctrl+V"), self)
        paste_shortcut.activated.connect(lambda: block_write_operation(self, "Paste (Ctrl+V)"))
        
        # Block Ctrl+D (Delete alternative)
        delete_alt_shortcut = QShortcut(QKeySequence("Ctrl+D"), self)
        delete_alt_shortcut.activated.connect(lambda: block_write_operation(self, "Delete (Ctrl+D)"))
        
        # =====================================================================
        # FORENSIC VIEW SHORTCUTS
        # =====================================================================
        
        # Ctrl+H - Hex View
        hex_shortcut = QShortcut(QKeySequence("Ctrl+H"), self)
        hex_shortcut.activated.connect(self._open_selected_hex)
        
        # Ctrl+T - Text View  
        text_shortcut = QShortcut(QKeySequence("Ctrl+T"), self)
        text_shortcut.activated.connect(self._open_selected_text)
        
        # Ctrl+S - Strings extraction
        strings_shortcut = QShortcut(QKeySequence("Ctrl+Shift+S"), self)
        strings_shortcut.activated.connect(self._open_selected_strings)
        
        # Enter - Open selected file
        enter_shortcut = QShortcut(QKeySequence("Return"), self)
        enter_shortcut.activated.connect(self._open_selected_file)
        
        # Ctrl+I - File details
        details_shortcut = QShortcut(QKeySequence("Ctrl+I"), self)
        details_shortcut.activated.connect(self._show_selected_details)
        
        # Ctrl+E - Export
        export_shortcut = QShortcut(QKeySequence("Ctrl+E"), self)
        export_shortcut.activated.connect(self._export_selected_file)
        
        # Log shortcuts setup to CoC
        self._log_coc("KEYBOARD_SHORTCUTS_INITIALIZED", {
            "blocked_operations": ["Delete", "Cut", "Rename", "Paste"],
            "forensic_shortcuts": ["Ctrl+H (Hex)", "Ctrl+T (Text)", "Ctrl+Shift+S (Strings)", "Ctrl+I (Details)"]
        })
    
    def _get_selected_node(self) -> Optional[VFSNode]:
        """Get currently selected node."""
        indexes = self.tree_view.selectedIndexes()
        if indexes:
            return self.model.get_node_by_index(indexes[0])
        return None
    
    def _open_selected_hex(self) -> None:
        """Open selected file in hex viewer."""
        node = self._get_selected_node()
        if node and not node.is_directory:
            self._open_with_viewer(node, "hex")
        elif not node:
            QMessageBox.information(self, "No Selection", "Please select a file first.")
    
    def _open_selected_text(self) -> None:
        """Open selected file in text viewer."""
        node = self._get_selected_node()
        if node and not node.is_directory:
            self._open_with_viewer(node, "text")
        elif not node:
            QMessageBox.information(self, "No Selection", "Please select a file first.")
    
    def _open_selected_strings(self) -> None:
        """Extract strings from selected file."""
        node = self._get_selected_node()
        if node and not node.is_directory:
            self._extract_strings(node)
        elif not node:
            QMessageBox.information(self, "No Selection", "Please select a file first.")
    
    def _open_selected_file(self) -> None:
        """Open selected file with appropriate viewer."""
        node = self._get_selected_node()
        if node:
            if node.is_directory:
                # Expand directory
                indexes = self.tree_view.selectedIndexes()
                if indexes:
                    self.tree_view.expand(indexes[0])
            else:
                self._open_file(node)
        else:
            QMessageBox.information(self, "No Selection", "Please select a file or folder first.")
    
    def _show_selected_details(self) -> None:
        """Show details for selected node."""
        node = self._get_selected_node()
        if node:
            self._show_details(node)
        else:
            QMessageBox.information(self, "No Selection", "Please select a file or folder first.")
    
    def _export_selected_file(self) -> None:
        """Export selected file."""
        node = self._get_selected_node()
        if node and not node.is_directory:
            self._export_file(node)
        elif node and node.is_directory:
            QMessageBox.information(self, "Cannot Export Folder", "Please select a file to export. Folder export is not currently supported.")
        else:
            QMessageBox.information(self, "No Selection", "Please select a file to export.")
    
    def _extract_strings(self, node: VFSNode):
        """Extract printable strings from file (forensic strings analysis)."""
        if not self.read_file_func:
            QMessageBox.warning(self, "Error", "File reading not available")
            return
        
        # Log to CoC
        self._log_coc("STRINGS_EXTRACTION_STARTED", {
            "path": node.path,
            "name": node.name,
            "size": node.size
        })
        
        # Show loading indicator
        self._show_loading(STATUS_EXTRACTING)
        QApplication.processEvents()
        
        try:
            # Read file data (limit to first MAX_FILE_SIZE_FOR_STRINGS for performance)
            data = self.read_file_func(node.path, 0, min(node.size or MAX_FILE_SIZE_FOR_STRINGS, MAX_FILE_SIZE_FOR_STRINGS))
            
            if not data:
                self._hide_loading()
                QMessageBox.warning(self, "Strings Extraction Error", "Could not read file data.\n\nThe file may be empty or inaccessible.")
                return
            
            # Extract ASCII strings (minimum MIN_STRING_LENGTH characters)
            import re
            ascii_pattern = rb'[\x20-\x7E]{' + str(MIN_STRING_LENGTH).encode() + rb',}'
            ascii_strings = re.findall(ascii_pattern, data)
            
            # Extract Unicode strings (UTF-16 LE, minimum 4 characters)
            unicode_pattern = rb'(?:[\x20-\x7E]\x00){4,}'
            unicode_matches = re.findall(unicode_pattern, data)
            unicode_strings = [m.decode('utf-16-le', errors='ignore') for m in unicode_matches]
            
            # Combine and deduplicate
            all_strings = set()
            for s in ascii_strings:
                try:
                    all_strings.add(s.decode('ascii', errors='ignore'))
                except:
                    pass
            all_strings.update(unicode_strings)
            
            # Sort by length (most interesting strings first)
            sorted_strings = sorted(all_strings, key=len, reverse=True)
            
            # Display in text viewer
            from src.ui.viewers import TextViewer
            
            header = f"""═══════════════════════════════════════════════════════════════════════
STRINGS EXTRACTION REPORT
═══════════════════════════════════════════════════════════════════════
File: {node.name}
Path: {node.path}
Size: {self._format_size(node.size or 0)}
Hash: {node.sha256 or 'Not computed'}
───────────────────────────────────────────────────────────────────────
Total strings found: {len(sorted_strings)}
Minimum string length: {MIN_STRING_LENGTH} characters
═══════════════════════════════════════════════════════════════════════

"""
            
            content = header + "\n".join(sorted_strings[:MAX_STRINGS_DISPLAY])
            
            if len(sorted_strings) > MAX_STRINGS_DISPLAY:
                content += f"\n\n[... {len(sorted_strings) - MAX_STRINGS_DISPLAY} more strings truncated ...]"
            
            self._hide_loading()
            
            viewer = TextViewer()
            viewer.setWindowTitle(f"Strings: {node.name}")
            viewer.display_content(content.encode('utf-8'))
            viewer.resize(800, 600)
            viewer.show()
            
            # Log to CoC
            self._log_coc("STRINGS_EXTRACTION_COMPLETE", {
                "path": node.path,
                "strings_found": len(sorted_strings),
                "ascii_count": len(ascii_strings),
                "unicode_count": len(unicode_strings)
            })
            
        except Exception as e:
            self._hide_loading()
            logger.error(f"Strings extraction failed for {node.path}: {e}")
            QMessageBox.critical(
                self, "Strings Extraction Error",
                f"Failed to extract strings from:\n{node.name}\n\nError: {str(e)}\n\nThe file may be corrupted, too large, or in an incompatible format."
            )
    
    # =========================================================================
    # NAVIGATION HISTORY
    # =========================================================================
    
    def _add_to_history(self, path: str) -> None:
        """Add path to navigation history."""
        # Remove any forward history when navigating to a new location
        if self._nav_position < len(self._nav_history) - 1:
            self._nav_history = self._nav_history[:self._nav_position + 1]
        
        # Add new path
        self._nav_history.append(path)
        self._nav_position = len(self._nav_history) - 1
        
        # Trim history if too large
        if len(self._nav_history) > NAV_HISTORY_MAX_SIZE:
            self._nav_history.pop(0)
            self._nav_position -= 1
        
        # Update button states
        self._update_nav_buttons()
    
    def _update_nav_buttons(self) -> None:
        """Update back/forward button enabled state."""
        self.btn_back.setEnabled(self._nav_position > 0)
        self.btn_forward.setEnabled(self._nav_position < len(self._nav_history) - 1)
    
    def _navigate_back(self) -> None:
        """Navigate to previous location in history."""
        if self._nav_position > 0:
            self._nav_position -= 1
            path = self._nav_history[self._nav_position]
            self._select_node_by_path(path)
            self._update_nav_buttons()
            self._log_coc("NAVIGATE_BACK", {"path": path, "history_position": self._nav_position})
    
    def _navigate_forward(self) -> None:
        """Navigate to next location in history."""
        if self._nav_position < len(self._nav_history) - 1:
            self._nav_position += 1
            path = self._nav_history[self._nav_position]
            self._select_node_by_path(path)
            self._update_nav_buttons()
            self._log_coc("NAVIGATE_FORWARD", {"path": path, "history_position": self._nav_position})
    
    def _navigate_up(self) -> None:
        """Navigate up one directory level."""
        if not self._current_path or self._current_path == "/":
            return
        
        # Get parent path
        parts = self._current_path.strip('/').split('/')
        if len(parts) > 1:
            parent_path = "/" + "/".join(parts[:-1])
            self._select_node_by_path(parent_path)
            self._add_to_history(parent_path)
            self._log_coc("NAVIGATE_UP", {"from_path": self._current_path, "to_path": parent_path})
    
    # =========================================================================
    # SEARCH FUNCTIONALITY
    # =========================================================================
    
    def _on_search_text_changed(self, text: str) -> None:
        """Handle search text change with debouncing."""
        if text:
            self._search_timer.start(SEARCH_DEBOUNCE_MS)
        else:
            self._search_timer.stop()
            self.model.refresh()  # Clear search when text is empty
    
    def _execute_search(self) -> None:
        """Execute search in file tree."""
        query = self.search_box.text().strip().lower()
        if not query:
            return
        
        self._show_loading(STATUS_SEARCHING)
        QApplication.processEvents()
        
        try:
            # Search through all nodes
            results = []
            self._search_nodes(self.vfs.get_root_nodes(), query, results)
            
            self._hide_loading()
            
            if results:
                # Show results count
                self.stats_label.setText(f"Found {len(results)} items")
                
                # Select first result
                if results:
                    self._select_node_by_path(results[0].path)
                
                self._log_coc("SEARCH_COMPLETED", {
                    "query": query,
                    "results_count": len(results)
                })
            else:
                self.stats_label.setText("No results found")
                QMessageBox.information(
                    self, "Search Results",
                    f"No files or folders matching '{query}' were found."
                )
        except Exception as e:
            self._hide_loading()
            logger.error(f"Search failed: {e}")
            QMessageBox.critical(self, "Search Error", f"Search failed: {str(e)}")
    
    def _search_nodes(self, nodes: List[VFSNode], query: str, results: List[VFSNode]) -> None:
        """Recursively search nodes for matching names."""
        for node in nodes:
            if query in node.name.lower():
                results.append(node)
            if node.is_directory and len(results) < 100:  # Limit results
                children = self.vfs.get_children(node.path)
                self._search_nodes(children, query, results)
    
    # =========================================================================
    # SORT & FILTER
    # =========================================================================
    
    def _on_sort_changed(self, sort_option: str) -> None:
        """Handle sort option change."""
        # Parse sort option (e.g., "Name ↑")
        parts = sort_option.split()
        if len(parts) < 2:
            return
        
        column_name = parts[0].lower()
        ascending = "↑" in parts[1]
        
        # Map column name to index
        column_map = {"name": 0, "size": 1, "type": 2, "date": 3}
        column_index = column_map.get(column_name, 0)
        
        # Sort the tree
        from PyQt6.QtCore import Qt
        order = Qt.SortOrder.AscendingOrder if ascending else Qt.SortOrder.DescendingOrder
        self.tree_view.sortByColumn(column_index, order)
        
        self._log_coc("SORT_CHANGED", {
            "column": column_name,
            "ascending": ascending
        })
    
    # =========================================================================
    # LOADING INDICATORS
    # =========================================================================
    
    def _show_loading(self, message: str = STATUS_LOADING) -> None:
        """Show loading indicator with animation."""
        self.loading_label.setText(message)
        self.loading_label.setVisible(True)
        
        # Start animation timer if not already running
        if not self._loading_timer:
            self._loading_timer = QTimer()
            self._loading_timer.timeout.connect(self._update_loading_animation)
            self._loading_timer.start(LOADING_ANIMATION_INTERVAL)
    
    def _update_loading_animation(self) -> None:
        """Update loading animation (rotating dots)."""
        if not self.loading_label.isVisible():
            if self._loading_timer:
                self._loading_timer.stop()
            return
        
        dots = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        current_text = self.loading_label.text()
        
        # Remove old spinner and add new one
        base_text = current_text.split()[0] if current_text else STATUS_LOADING.split()[0]
        self._loading_dots = (self._loading_dots + 1) % len(dots)
        self.loading_label.setText(f"{base_text} {dots[self._loading_dots]}")
    
    def _hide_loading(self) -> None:
        """Hide loading indicator."""
        self.loading_label.setVisible(False)
        if self._loading_timer:
            self._loading_timer.stop()
        self._loading_dots = 0
    
    # =========================================================================
    # TERMINAL INTEGRATION
    # =========================================================================
    
    def sync_to_terminal_path(self, terminal_path: str):
        """
        Sync file browser to terminal's current path.
        
        Called when terminal 'cd' command changes directory.
        Updates the Files Tab selection to match.
        
        Terminal Integration:
        - When terminal runs 'cd /Disk0/C:/Users/Victim'
        - Files tab auto-selects that folder
        - Breadcrumb updates to show forensic path
        - User context badge shows '👤 Victim'
        """
        if not terminal_path:
            return
            
        # Normalize path
        terminal_path = terminal_path.replace('\\', '/')
        
        # Show sync activity
        self.sync_indicator.setText("🔄 Syncing...")
        self.sync_indicator.setStyleSheet("color: #FFA500; font-size: 10px; padding: 2px 6px;")
        
        # Find matching node in VFS
        try:
            node = self.vfs.get_node(terminal_path)
            if node:
                # Find index for this node and select it
                self._select_node_by_path(terminal_path)
                
                # Update breadcrumb
                self._update_breadcrumb(terminal_path)
                self._current_path = terminal_path
                
                # Detect user context
                self._current_user = self._detect_user_context(terminal_path)
                if self._current_user:
                    self.user_context_label.setText(f"👤 {self._current_user}")
                    self.user_context_label.setVisible(True)
                else:
                    self.user_context_label.setText("")
                    self.user_context_label.setVisible(False)
                
                # Show sync success
                self.sync_indicator.setText("🔗 Synced")
                self.sync_indicator.setStyleSheet("color: #4CAF50; font-size: 10px; padding: 2px 6px;")
                
                self._log_coc("TERMINAL_SYNC_SUCCESS", {
                    "terminal_path": terminal_path,
                    "user_context": self._current_user
                })
            else:
                # Path not found in VFS
                self.sync_indicator.setText("⚠ Not Found")
                self.sync_indicator.setStyleSheet("color: #FFA500; font-size: 10px; padding: 2px 6px;")
                
                self._log_coc("TERMINAL_SYNC_NOT_FOUND", {
                    "terminal_path": terminal_path
                })
        except Exception as e:
            logger.warning(f"Failed to sync to terminal path: {e}")
            self.sync_indicator.setText("⚠ Error")
            self.sync_indicator.setStyleSheet("color: #ff5555; font-size: 10px; padding: 2px 6px;")
    
    def _select_node_by_path(self, path: str):
        """Select a node in the tree view by its path."""
        # Build path segments to expand
        parts = path.strip('/').split('/')
        
        # Start from root and expand each level
        parent_index = QModelIndex()
        for i, part in enumerate(parts):
            found = False
            for row in range(self.model.rowCount(parent_index)):
                index = self.model.index(row, 0, parent_index)
                node = self.model.get_node_by_index(index)
                if node and node.name == part:
                    self.tree_view.expand(index)
                    parent_index = index
                    found = True
                    break
            
            if not found:
                break
        
        # Select the final node
        if parent_index.isValid():
            self.tree_view.setCurrentIndex(parent_index)
            self.tree_view.scrollTo(parent_index)
    
    def get_current_path(self) -> str:
        """Get current selected path for terminal sync."""
        return self._current_path or "/"
    
    def get_current_user(self) -> Optional[str]:
        """Get current user context for terminal prompt."""
        return self._current_user
    
    def navigate_to_path(self, path: str):
        """
        Navigate to a specific path in the evidence.
        
        This is the main method for programmatic navigation.
        """
        self.sync_to_terminal_path(path)
        
        # Emit signal to sync terminal
        self.path_changed.emit(path)
        
        # Check for user context change
        user = self._detect_user_context(path)
        if user != self._current_user:
            self._current_user = user
            self.user_context_changed.emit(user or "")
    
    def execute_terminal_cd(self, path: str):
        """
        Execute a 'cd' command in the terminal for this path.
        
        Called when user double-clicks a folder.
        """
        self.terminal_command.emit(f"cd {path}")
    
    # =========================================================================
    # CHAIN OF CUSTODY & UTILITY
    # =========================================================================
    
    def _log_coc(self, action: str, details: Dict):
        """Log action to Chain of Custody."""
        if self.coc_logger:
            try:
                self.coc_logger(action, details)
            except Exception as e:
                logger.warning(f"Failed to log CoC: {e}")
    
    def _format_size(self, size: int) -> str:
        """Format byte size."""
        size_f = float(size)
        for unit in ['B', 'KB', 'MB', 'GB']:
            if size_f < 1024:
                return f"{size_f:.1f} {unit}"
            size_f /= 1024
        return f"{size_f:.1f} TB"
    
    def set_integrity_status(self, ok: bool, message: str = ""):
        """Update the integrity status indicator."""
        if ok:
            self.integrity_indicator.setText("✓ Integrity OK")
            self.integrity_indicator.setStyleSheet("color: #4CAF50; font-size: 10px; padding: 2px 6px;")
            self.integrity_indicator.setToolTip(message or "Evidence integrity has not been compromised")
        else:
            self.integrity_indicator.setText("⚠ Integrity Warning")
            self.integrity_indicator.setStyleSheet("color: #FFA500; font-size: 10px; padding: 2px 6px;")
            self.integrity_indicator.setToolTip(message or "Evidence integrity status unknown")
