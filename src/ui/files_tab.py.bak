class DetailsPanel(QFrame):
    """
    Right-side panel showing file details.
    """
    
    def __init__(self, parent=None):
        super().__init__(parent)
        self._setup_ui()
    
    def _setup_ui(self):
        """Set up the details panel UI."""
        self.setStyleSheet("""
            DetailsPanel {
                background: #252525;
                border-left: 1px solid #3d3d3d;
            }
            QLabel {
                color: #e0e0e0;
            }
        """)
        
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        
        # Icon and name
        self.icon_label = QLabel("📁")
        self.icon_label.setStyleSheet("font-size: 64px;")
        self.icon_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        layout.addWidget(self.icon_label)
        
        self.name_label = QLabel("Select a file")
        self.name_label.setStyleSheet("""
            font-size: 14px;
            font-weight: bold;
            color: #e0e0e0;
        """)
        self.name_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self.name_label.setWordWrap(True)
        layout.addWidget(self.name_label)
        
        self.type_label = QLabel("")
        self.type_label.setStyleSheet("color: #888; font-size: 12px;")
        self.type_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        layout.addWidget(self.type_label)
        
        layout.addSpacing(16)
        
        # Read-only badge
        readonly_badge = QLabel("🔒 Read-Only")
        readonly_badge.setStyleSheet("""
            color: #4CAF50;
            font-size: 10px;
            padding: 2px 8px;
            background: #1b3d1b;
            border-radius: 3px;
        """)
        readonly_badge.setAlignment(Qt.AlignmentFlag.AlignCenter)
        readonly_badge.setVisible(False)  # Hide forensic badge for clean look
        layout.addWidget(readonly_badge)
        
        layout.addSpacing(16)
        
        # Details form - Windows Properties style
        self.details_layout = QFormLayout()
        self.details_layout.setSpacing(8)
        self.details_layout.setLabelAlignment(Qt.AlignmentFlag.AlignRight)
        
        self._add_detail_row("Size:", "size_value")
        self._add_detail_row("Date created:", "created_value")
        self._add_detail_row("Date modified:", "modified_value")
        self._add_detail_row("Date accessed:", "accessed_value")
        
        # Separator line
        layout.addSpacing(8)
        separator = QFrame()
        separator.setFrameShape(QFrame.Shape.HLine)
        separator.setStyleSheet("background: #3d3d3d;")
        
        self._add_detail_row("Location:", "path_value")
        
        # Hidden forensic fields (still accessible via tooltip)
        self._add_detail_row("", "sha256_value")
        self._add_detail_row("", "evidence_value")  
        self._add_detail_row("", "partition_value")
        
        # Hide forensic-specific fields
        self.sha256_value.setVisible(False)
        self.evidence_value.setVisible(False)
        self.partition_value.setVisible(False)
        
        layout.addLayout(self.details_layout)
        layout.addStretch()
    
    def _add_detail_row(self, label_text: str, value_name: str):
        """Add a detail row to the form."""
        label = QLabel(label_text)
        label.setStyleSheet("color: #888;")
        
        value = QLabel("—")
        value.setStyleSheet("color: #d4d4d4;")
        value.setWordWrap(True)
        value.setTextInteractionFlags(Qt.TextInteractionFlag.TextSelectableByMouse)
        
        setattr(self, value_name, value)
        self.details_layout.addRow(label, value)
    
    def show_node(self, node: VFSNode):
        """Display node details."""
        # Icon
        icons = {
            VFSNodeType.ROOT: "🖥️",
            VFSNodeType.DISK: "💽",
            VFSNodeType.PARTITION: "📦",
            VFSNodeType.DRIVE: "💾",
            VFSNodeType.FOLDER: "📁",
            VFSNodeType.FILE: "📄",
            VFSNodeType.USER: "👤",
            VFSNodeType.SYSTEM: "⚙️",
            VFSNodeType.SYMLINK: "🔗",
            VFSNodeType.DELETED: "🗑️",
        }
        self.icon_label.setText(icons.get(node.node_type, "📄"))
        
        # Name and type
        self.name_label.setText(node.name)
        self.type_label.setText(node.node_type.value.replace('_', ' ').title())
        
        # Size
        if node.size > 0:
            self.size_value.setText(f"{self._format_size(node.size)} ({node.size:,} bytes)")
        else:
            self.size_value.setText("—")
        
        # Timestamps - Windows Properties style format
        if node.created:
            self.created_value.setText(node.created.strftime("%A, %B %d, %Y, %I:%M %p"))
        else:
            self.created_value.setText("—")
        
        if node.modified:
            self.modified_value.setText(node.modified.strftime("%A, %B %d, %Y, %I:%M %p"))
        else:
            self.modified_value.setText("—")
        
        if node.accessed:
            self.accessed_value.setText(node.accessed.strftime("%A, %B %d, %Y, %I:%M %p"))
        else:
            self.accessed_value.setText("—")
        
        # Hash
        if node.sha256:
            # Show truncated hash with full hash on tooltip
            self.sha256_value.setText(f"{node.sha256[:16]}...")
            self.sha256_value.setToolTip(f"Full SHA-256: {node.sha256}")
        else:
            self.sha256_value.setText("—")
            self.sha256_value.setToolTip("Hash not yet computed")
        
        # Evidence source
        self.evidence_value.setText(node.evidence_id or "—")
        
        # Partition info
        self.partition_value.setText(node.partition_info or "—")
        
        # Full path - Windows style (C:\Users\John\Desktop)
        # CRITICAL: Must use sanitized path only!
        if node.path:
            # Convert internal path to Windows display path
            parts = node.path.strip('/').split('/')
            if parts and parts[0] == 'This PC' and len(parts) > 1:
                if ':' in parts[1]:
                    # Drive letter path: /This PC/C:/Users/John -> C:\Users\John
                    drive = parts[1]
                    if len(parts) > 2:
                        display_path = drive + "\\" + "\\".join(parts[2:])
                    else:
                        display_path = drive + "\\"
                else:
                    # Special partition: /This PC/Recovery/... -> Recovery\...
                    display_path = "\\".join(parts[1:])
            else:
                # Fallback: just convert slashes
                display_path = "\\".join(parts)
            
            # FORENSIC INTEGRITY: Sanitize before display
            display_path = sanitize_display_path(display_path, "details_panel")
            
            self.path_value.setText(display_path)
            self.path_value.setToolTip(display_path)
        else:
            self.path_value.setText("—")
    
    def clear(self):
        """Clear the details panel."""
        self.icon_label.setText("📁")
        self.name_label.setText("Select a file")
        self.type_label.setText("")
        self.size_value.setText("—")
        self.created_value.setText("—")
        self.modified_value.setText("—")
        self.accessed_value.setText("—")
        self.sha256_value.setText("—")
        self.evidence_value.setText("—")
        self.partition_value.setText("—")
        self.path_value.setText("—")
    
    def _format_size(self, size: int) -> str:
        """Format byte size."""
        size_f = float(size)
        for unit in ['B', 'KB', 'MB', 'GB']:
            if size_f < 1024:
                return f"{size_f:.1f} {unit}"
            size_f /= 1024
        return f"{size_f:.1f} TB"


# ============================================================================
# FILES TAB
# ============================================================================

class FilesTab(QWidget):
    """
    Main Files tab widget - forensic file explorer.
    
    Layout:
        ┌────────────────────────────────────────────┐
        │  🖥️ This Case                              │
        │  ├─ 💽 Disk0                               │
        │  │  └─ 💾 C:                               │
        │  │      ├─ 📁 Windows                      │
        │  │      └─ 👤 Users                        │
        │  └─ 💽 Disk1                               │
        └────────────────────────────────────────────┘
    
    Terminal Sync:
        Selecting 👤 Victim updates terminal to:
        fepd:CaseName[Victim]$
    """
    
    # Signals
    file_opened = pyqtSignal(str, str)       # path, action
    node_selected = pyqtSignal(object)        # VFSNode
    path_changed = pyqtSignal(str)            # new path for terminal sync
    user_context_changed = pyqtSignal(str)    # user profile name for terminal
    terminal_command = pyqtSignal(str)        # command to execute in terminal
    write_blocked = pyqtSignal(str)           # blocked action name
    
    def __init__(
        self,
        vfs: VirtualFilesystem,
        read_file_func: Optional[Callable[[str, int, int], bytes]] = None,
        coc_logger: Optional[Callable[[str, Dict], None]] = None,
        parent=None
    ):
        """
        Initialize Files tab.
        
        Args:
            vfs: VirtualFilesystem instance
            read_file_func: Function to read file bytes from evidence
            coc_logger: Chain of custody logging function
            parent: Parent widget
        """
        super().__init__(parent)
        
        self.vfs = vfs
        self.read_file_func = read_file_func
        self.coc_logger = coc_logger
        
        # Controller (new architecture)
        self.controller = FilesController(
            vfs=vfs,
            read_file_func=read_file_func,
            coc_logger=coc_logger,
            parent=self,
        )
        
        # Contents table model (center panel)
        self._contents_model = FolderContentsModel(parent=self)
        
        self._viewers = {}  # Active viewers
        self._current_path = "/"  # Current navigation path
        self._current_user = None  # Current user context for terminal
        
        # Navigation history
        self._nav_history: List[str] = []  # Navigation history stack
        self._nav_position = -1  # Current position in history
        
        # Hash cache
        self._hash_cache: Dict[str, Dict[str, str]] = {}  # path -> {sha256, md5}
        
        # Lazy loading state
        self._lazy_load_active = False
        self._lazy_load_items: List[VFSNode] = []
        self._lazy_load_index = 0
        
        # Loading indicator timer
        self._loading_timer: Optional[QTimer] = None
        self._loading_dots = 0
        
        self._setup_ui()
        self._setup_keyboard_shortcuts()
        self._connect_controller_signals()
    
