def block_write_operation(parent_widget, action_name: str = "operation"):
    """
    Display forensic write-block warning.
    
    Args:
        parent_widget: Parent widget for dialog
        action_name: Name of blocked action
    """
    QMessageBox.warning(
        parent_widget,
        "⛔ Forensic Write Block",
        WRITE_BLOCK_MESSAGE,
        QMessageBox.StandardButton.Ok
    )
    return False


def is_user_profile_folder(name: str) -> bool:
    """Check if folder name looks like a user profile."""
    name_lower = name.lower()
    # Exclude system folders
    if name_lower in ('windows', 'program files', 'program files (x86)', 
                      'programdata', 'recovery', 'system volume information'):
        return False
    return True


# ============================================================================
# VFS TREE MODEL
# ============================================================================

class VFSTreeModel(QAbstractItemModel):
    """
    Qt model for displaying VFS tree in a QTreeView.
    
    Lazy-loads children on demand for performance with large filesystems.
    """
    
    def __init__(self, vfs: VirtualFilesystem, parent=None):
        super().__init__(parent)
        self.vfs = vfs
        self._root_nodes: List[VFSNode] = []
        self._children_cache: Dict[str, List[VFSNode]] = {}
        self._node_cache: Dict[str, VFSNode] = {}
        
        self.refresh()
    
    def refresh(self):
        """Refresh the model from VFS."""
        self.beginResetModel()
        self._root_nodes = self.vfs.get_root_nodes()
        self._children_cache.clear()
        self._node_cache.clear()
        
        # Cache root nodes
        for node in self._root_nodes:
            self._node_cache[node.path] = node
        
        self.endResetModel()
    
    def _get_children(self, parent_path: str) -> List[VFSNode]:
        """Get children of a path, using cache."""
        if parent_path not in self._children_cache:
            children = self.vfs.get_children(parent_path)
            self._children_cache[parent_path] = children
            for child in children:
                self._node_cache[child.path] = child
        return self._children_cache[parent_path]
    
    def rowCount(self, parent: QModelIndex = QModelIndex()) -> int:
        if not parent.isValid():
            return len(self._root_nodes)
        
        node: VFSNode = parent.internalPointer()
        if node.is_directory:
            return len(self._get_children(node.path))
        return 0
    
    def columnCount(self, parent: QModelIndex = QModelIndex()) -> int:
        return 4  # Name, Size, Type, Modified
    
    def index(self, row: int, column: int, parent: QModelIndex = QModelIndex()) -> QModelIndex:
        if not self.hasIndex(row, column, parent):
            return QModelIndex()
        
        if not parent.isValid():
            # Root level
            if row < len(self._root_nodes):
                return self.createIndex(row, column, self._root_nodes[row])
        else:
            # Child level
            parent_node: VFSNode = parent.internalPointer()
            children = self._get_children(parent_node.path)
            if row < len(children):
                return self.createIndex(row, column, children[row])
        
        return QModelIndex()
    
    def parent(self, index: QModelIndex) -> QModelIndex:
        if not index.isValid():
            return QModelIndex()
        
        node: VFSNode = index.internalPointer()
        
        if not node.parent_path:
            return QModelIndex()
        
        # Find parent node
        parent_node = self._node_cache.get(node.parent_path)
        if not parent_node:
            parent_node = self.vfs.get_node(node.parent_path)
            if parent_node:
                self._node_cache[parent_node.path] = parent_node
        
        if not parent_node:
            return QModelIndex()
        
        # Find row of parent
        if not parent_node.parent_path:
            # Parent is at root level
            try:
                row = self._root_nodes.index(parent_node)
            except ValueError:
                # Search by path
                for i, n in enumerate(self._root_nodes):
                    if n.path == parent_node.path:
                        row = i
                        break
                else:
                    return QModelIndex()
            return self.createIndex(row, 0, parent_node)
        else:
            # Parent is a child of something
            grandparent_children = self._get_children(parent_node.parent_path)
            for i, n in enumerate(grandparent_children):
                if n.path == parent_node.path:
                    return self.createIndex(i, 0, parent_node)
        
        return QModelIndex()
    
    def data(self, index: QModelIndex, role: int = Qt.ItemDataRole.DisplayRole):
        if not index.isValid():
            return None
        
        node: VFSNode = index.internalPointer()
        column = index.column()
        
        if role == Qt.ItemDataRole.DisplayRole:
            if column == 0:
                return node.name
            elif column == 1:
                if node.is_directory:
                    return ""
                return self._format_size(node.size)
            elif column == 2:
                return self._get_type_text(node)
            elif column == 3:
                if node.modified:
                    return node.modified.strftime("%Y-%m-%d %H:%M")
                return ""
        
        elif role == Qt.ItemDataRole.DecorationRole and column == 0:
            return self._get_icon(node)
        
        elif role == Qt.ItemDataRole.ForegroundRole:
            if node.is_deleted:
                return QColor("#888888")
            if node.node_type == VFSNodeType.SYSTEM:
                return QColor("#888888")
        
        elif role == Qt.ItemDataRole.ToolTipRole:
            return node.path
        
        elif role == Qt.ItemDataRole.UserRole:
            # Return the node itself
            return node
        
        return None
    
    def headerData(self, section: int, orientation: Qt.Orientation, role: int = Qt.ItemDataRole.DisplayRole):
        if orientation == Qt.Orientation.Horizontal and role == Qt.ItemDataRole.DisplayRole:
            headers = ["Name", "Size", "Type", "Modified"]
            if section < len(headers):
                return headers[section]
        return None
    
    def hasChildren(self, parent: QModelIndex = QModelIndex()) -> bool:
        if not parent.isValid():
            return len(self._root_nodes) > 0
        
        node: VFSNode = parent.internalPointer()
        return node.is_directory
    
    def canFetchMore(self, parent: QModelIndex) -> bool:
        if not parent.isValid():
            return False
        
        node: VFSNode = parent.internalPointer()
        if not node.is_directory:
            return False
        
        return node.path not in self._children_cache
    
    def fetchMore(self, parent: QModelIndex):
        if not parent.isValid():
            return
        
        node: VFSNode = parent.internalPointer()
        if node.path not in self._children_cache:
            children = self.vfs.get_children(node.path)
            self._children_cache[node.path] = children
            for child in children:
                self._node_cache[child.path] = child
    
    def _get_icon(self, node: VFSNode) -> str:
        """Get icon for node - Windows Explorer style."""
        # Check for special nodes first based on name
        name_lower = node.name.lower()
        
        # "This PC" root node
        if name_lower == 'this pc' or (node.metadata and node.metadata.get('is_this_pc')):
            return "🖥️"
        
        # Drive letters with "Local Disk" prefix
        if name_lower.startswith('local disk') or (node.node_type == VFSNodeType.DRIVE and ':' in node.name):
            return "💾"
        
        # System partitions
        if name_lower in ('recovery', 'efi system', 'efi_system', 'system reserved', 'system_reserved'):
            return "⚙️"
        
        # Special Windows folders
        special_folder_icons = {
            'desktop': '🖥️',
            'documents': '📄',
            'downloads': '📥',
            'pictures': '🖼️',
            'music': '🎵',
            'videos': '🎬',
            'appdata': '📁',
            '$recycle.bin': '🗑️',
            'system volume information': '⚙️',
            'windows': '⚙️',
            'program files': '📂',
            'program files (x86)': '📂',
            'programdata': '📂',
        }
        
        if name_lower in special_folder_icons:
            return special_folder_icons[name_lower]
        
        # Default icons by type
        icons = {
            VFSNodeType.ROOT: "🖥️",
            VFSNodeType.DISK: "💽",
            VFSNodeType.PARTITION: "📦",
            VFSNodeType.DRIVE: "💾",
            VFSNodeType.FOLDER: "📁",
            VFSNodeType.FILE: "📄",
            VFSNodeType.USER: "👤",
            VFSNodeType.SYSTEM: "⚙️",
            VFSNodeType.SYMLINK: "🔗",
            VFSNodeType.DELETED: "🗑️",
        }
        
        # File type specific icons
        if node.node_type == VFSNodeType.FILE:
            ext = node.name.lower().rsplit('.', 1)[-1] if '.' in node.name else ''
            if ext in ('pdf',):
                return "📕"
            elif ext in ('jpg', 'jpeg', 'png', 'gif', 'bmp', 'ico', 'tiff', 'webp'):
                return "🖼️"
            elif ext in ('mp4', 'avi', 'mkv', 'mov', 'wmv', 'webm', 'flv'):
                return "🎬"
            elif ext in ('mp3', 'wav', 'flac', 'ogg', 'aac', 'm4a', 'wma'):
                return "🎵"
            elif ext in ('exe', 'dll', 'sys', 'com', 'bat', 'cmd', 'msi'):
                return "⚡"
            elif ext in ('zip', 'rar', '7z', 'tar', 'gz', 'bz2', 'xz', 'cab'):
                return "📦"
            elif ext in ('doc', 'docx', 'odt', 'rtf'):
                return "📘"
            elif ext in ('xls', 'xlsx', 'ods', 'csv'):
                return "📊"
            elif ext in ('ppt', 'pptx', 'odp'):
                return "📽️"
            elif ext in ('txt', 'log', 'md', 'cfg', 'ini', 'conf'):
                return "📝"
            elif ext in ('html', 'htm', 'xml', 'json', 'yaml', 'yml'):
                return "🌐"
            elif ext in ('py', 'js', 'java', 'cpp', 'c', 'h', 'cs', 'go', 'rs'):
                return "💻"
            elif ext in ('db', 'sqlite', 'sqlite3', 'mdb', 'accdb'):
                return "🗃️"
            # Email/Outlook files - CRITICAL for forensics
            elif ext in ('pst', 'ost'):
                return "📧"  # Outlook email archives
            elif ext in ('eml', 'msg', 'mbox'):
                return "✉️"  # Individual email messages
            # Browser artifacts
            elif ext in ('dat', 'lnk'):
                return "🔗"
            # Registry/System
            elif ext in ('reg', 'hiv'):
                return "🗝️"
            # Event logs
            elif ext in ('evtx', 'evt', 'etl'):
                return "📋"
            # Forensic image files
            elif ext in ('e01', 'l01', 'ex01', 'dd', 'raw', 'img', 'aff', 'aff4'):
                return "💿"
            # Memory dumps
            elif ext in ('mem', 'dmp', 'vmem', 'hiberfil'):
                return "🧠"
            # Mobile backups
            elif ext in ('ab', 'backup', 'ipsw'):
                return "📱"
            # Network captures
            elif ext in ('pcap', 'pcapng', 'cap'):
                return "🌐"
        
        return icons.get(node.node_type, "📄")
    
    def _get_type_text(self, node: VFSNode) -> str:
        """Get type description text."""
        if node.node_type == VFSNodeType.DISK:
            return "Disk Image"
        elif node.node_type == VFSNodeType.DRIVE:
            return node.partition_info or "Drive"
        elif node.node_type == VFSNodeType.USER:
            return "User Profile"
        elif node.node_type == VFSNodeType.SYSTEM:
            return "System Folder"
        elif node.node_type == VFSNodeType.FOLDER:
            return "Folder"
        elif node.node_type == VFSNodeType.DELETED:
            return "Deleted"
        elif node.node_type == VFSNodeType.FILE:
            if node.mime_type:
                return node.mime_type.split('/')[-1].title()
            ext = node.name.rsplit('.', 1)[-1].lower() if '.' in node.name else ''
            # Special forensic file types with descriptive names
            type_map = {
                'pst': 'Outlook Personal Folders',
                'ost': 'Outlook Offline Folders',
                'eml': 'Email Message',
                'msg': 'Outlook Message',
                'mbox': 'Mailbox Archive',
                'evtx': 'Windows Event Log',
                'evt': 'Legacy Event Log',
                'etl': 'Event Trace Log',
                'e01': 'EnCase Image',
                'l01': 'EnCase Logical',
                'dd': 'Raw Disk Image',
                'raw': 'Raw Image',
                'pcap': 'Network Capture',
                'pcapng': 'Network Capture',
                'lnk': 'Windows Shortcut',
                'pf': 'Prefetch File',
                'reg': 'Registry Export',
                'mem': 'Memory Dump',
                'dmp': 'Crash Dump',
                'vmem': 'Virtual Memory',
                'sqlite': 'SQLite Database',
                'sqlite3': 'SQLite Database',
                'db': 'Database File',
            }
            if ext in type_map:
                return type_map[ext]
            return f"{ext.upper()} File" if ext else "File"
        
        return node.node_type.value.replace('_', ' ').title()
    
    def _format_size(self, size: int) -> str:
        """Format byte size."""
        if size == 0:
            return ""
        size_f = float(size)
        for unit in ['B', 'KB', 'MB', 'GB']:
            if size_f < 1024:
                if unit == 'B':
                    return f"{int(size_f)} {unit}"
                return f"{size_f:.1f} {unit}"
            size_f /= 1024
        return f"{size_f:.1f} TB"
    
    def get_node_by_index(self, index: QModelIndex) -> Optional[VFSNode]:
        """Get VFSNode from model index."""
        if index.isValid():
            return index.internalPointer()
        return None


